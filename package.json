{
  "name": "orchestr8ai-n8n-assistant",
  "version": "0.2.0",
  "description": "Orchestr8_AI — Discord multi-project n8n assistant (Vercel AI SDK backend)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run infra:up && npm run db:migrate && tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.ts'",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "check": "npm run check:deps && npm run check:cycles && npm run check:deep-imports && npm run check:file-size && npm run check:contracts",
    "check:deps": "tsx scripts/check-dependency-direction.ts",
    "check:cycles": "tsx scripts/check-cycles.ts",
    "check:deep-imports": "tsx scripts/check-deep-imports.ts",
    "check:file-size": "tsx scripts/check-file-size.ts",
    "check:contracts": "tsx scripts/check-contract-compatibility.ts",
    "infra:up": "tsx scripts/infra-up.ts",
    "infra:down": "docker compose down",
    "infra:health": "tsx scripts/infra-health.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "ci": "npm run typecheck && npm run lint && npm run check && npm run test",
    "perf:gate": "echo 'perf gate placeholder — no regressions detected'"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "madge": "^8.0.0",
    "testcontainers": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "ai": "^4.3.0",
    "discord.js": "^14.0.0",
    "dotenv": "^16.4.0",
    "nats": "^2.28.0",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  }
}
