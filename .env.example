# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_discord_server_id
ORCHESTRATOR_CHANNEL_ID=channel_id_for_orchestrator

# Optional: place new project channels inside a category
PROJECTS_CATEGORY_ID=

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose your provider and set the matching model name and API key.
#
# anthropic      → models: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
#                  key at: console.anthropic.com
#
# openai         → models: gpt-4o, gpt-4o-mini, o3, o4-mini
#                  key at: platform.openai.com
#
# google         → models: gemini-2.0-flash, gemini-2.0-pro, gemini-1.5-pro
#                  key at: aistudio.google.com
#
# mistral        → models: mistral-large-latest, mistral-small-latest
#                  key at: console.mistral.ai
#
# groq           → models: llama-3.3-70b-versatile, deepseek-r1-distill-llama-70b
#                  key at: console.groq.com
#
# xai            → models: grok-2, grok-3
#                  key at: console.x.ai
#
# cohere         → models: command-r-plus, command-r
#                  key at: dashboard.cohere.com
#
# deepseek       → models: deepseek-chat, deepseek-reasoner
#                  key at: platform.deepseek.com
#
# openai-compatible → any OpenAI-compatible API (Together AI, Perplexity, Ollama, etc.)
#                     requires AI_BASE_URL to be set
#
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-6
AI_API_KEY=your_api_key_here
# AI_BASE_URL=   # required for openai-compatible, optional for others

# ── Security ──────────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of n8n API keys at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Read-only web dashboard at http://localhost:3000/dashboard
# Leave blank to disable the dashboard entirely.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change_me
# DASHBOARD_PORT=3000   # default: 3000

# ── Infrastructure ────────────────────────────────────────────────────────────
# These defaults match docker-compose.yml — change only if you customise the stack
DATABASE_URL=postgresql://orchestr8ai:orchestr8ai_dev@localhost:5432/orchestr8ai_dev
NATS_URL=nats://localhost:4222
